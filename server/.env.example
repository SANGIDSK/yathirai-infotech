# ═══════════════════════════════════════════════════════════════════
# YATHIRAI INFOTECH — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git — it's in .gitignore already.
# ═══════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Frontend URL (for CORS) ───────────────────────────────────────
# In production, set this to your deployed frontend URL
FRONTEND_URL=http://localhost:5173

# ─── Email (SMTP) Configuration ───────────────────────────────────
# For Gmail: Enable 2-Step Verification, then create an App Password at:
# https://myaccount.google.com/apppasswords
#
# For other providers (Zoho, SendGrid, etc.), update HOST and PORT.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Your sending email address (can be a Gmail/Zoho/etc. account)
SMTP_USER=your-email@gmail.com

# App Password (NOT your regular Gmail password)
SMTP_PASS=your-app-password-here

# ─── Optional: MongoDB (for future use) ───────────────────────────
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/yathirai
